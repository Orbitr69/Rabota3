#include <iostream>
#include <fstream>
#include <algorithm> // для std::sort
#include "Student.h"

// Функция для вычисления среднего балла студента
double calculateAverage(const STUDENT& student) {
    double sum = 0;
    for (int i = 0; i < 5; ++i) {
        sum += student.grades[i];
    }
    return sum / 5.0;
}

int main() {
    setlocale(LC_ALL, "Russian"); // Для поддержки русского языка в консоли
    const int SIZE = 10;
    STUDENT students[SIZE];

    // 1. Ввод данных в массив
    std::cout << "--- Ввод данных о студентах ---\n";
    for (int i = 0; i < SIZE; ++i) {
        std::cout << "\nСтудент #" << i + 1 << ":\n";
        std::cin >> students[i];
    }

    // 2. Сортировка по возрастанию номера группы (пузырьковая сортировка)
    for (int i = 0; i < SIZE - 1; ++i) {
        for (int j = 0; j < SIZE - i - 1; ++j) {
            // Используем перегруженный оператор >
            if (students[j] > students[j + 1]) {
                // Меняем местами
                STUDENT temp = students[j];
                students[j] = students[j + 1];
                students[j + 1] = temp;
            }
        }
    }
    std::cout << "\n--- Сортировка завершена ---\n";

    // 3. Запись в двоичный файл
    std::ofstream outFile("students.bin", std::ios::binary);
    if (!outFile) {
        std::cerr << "Ошибка открытия файла для записи!" << std::endl;
        return 1;
    }
    // Записываем весь массив структур как блок байт
    outFile.write(reinterpret_cast<char*>(students), SIZE * sizeof(STUDENT));
    outFile.close();
    std::cout << "Данные записаны в файл students.bin\n";

    // 4. Чтение из двоичного файла (для проверки)
    STUDENT readStudents[SIZE];
    std::ifstream inFile("students.bin", std::ios::binary);
    if (!inFile) {
        std::cerr << "Ошибка открытия файла для чтения!" << std::endl;
        return 1;
    }
    inFile.read(reinterpret_cast<char*>(readStudents), SIZE * sizeof(STUDENT));
    inFile.close();
    std::cout << "Данные прочитаны из файла students.bin\n";

    // 5. Вывод студентов со средним баллом > 4.0
    std::cout << "\n--- Студенты со средним баллом > 4.0 ---\n";
    bool found = false;
    for (int i = 0; i < SIZE; ++i) {
        if (calculateAverage(readStudents[i]) > 4.0) {
            std::cout << readStudents[i].fullName << ", группа " << readStudents[i].groupNumber << std::endl;
            found = true;
        }
    }

    if (!found) {
        std::cout << "Студентов со средним баллом выше 4.0 нет.\n";
    }

    return 0;
}
